# ===================================
# 国内基金每日分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# ===================================
# 自选基金列表（逗号分隔，天天基金代码）
# 示例：110022 易方达蓝筹精选、003095 中欧医疗健康、100032 富国天惠
# ===================================
FUND_LIST=110022,003095,100032

# 分析回看天数（默认30天历史净值）
REPORT_DAYS=30
# 报告格式：summary（仅汇总）/ simple（精简快读）/ full（完整仪表盘）
REPORT_TYPE=full
# 仅推送汇总（true 时忽略 REPORT_TYPE，直接使用 summary）
REPORT_SUMMARY_ONLY=false

# ===================================
# AI 模型配置（二选一，至少配置一个）
# ===================================

# 【方案一】Gemini（推荐，有免费额度）
# 从 https://aistudio.google.com/ 获取免费 API Key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7

# 【方案二】OpenAI 兼容 API（支持 DeepSeek、通义千问等国产模型）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# OPENAI_TEMPERATURE=0.7

# ===================================
# 通知渠道（可同时配置多个）
# ===================================

# 【方式一】Telegram 机器人（推荐）
# 1. 在 Telegram 找 @BotFather -> /newbot -> 获取 Bot Token
# 2. 获取 Chat ID：发消息给 @userinfobot 或访问
#    https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 如发送到 Telegram 话题（Topic），可额外配置：
# TELEGRAM_MESSAGE_THREAD_ID=

# 【方式二】邮件推送（SMTP，支持 QQ/163/Gmail/Outlook）
# QQ邮箱：设置 -> 账户 -> POP3/SMTP服务 -> 开启 -> 获取授权码
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_email_auth_code
# 收件人（逗号分隔；留空则发给自己）
EMAIL_RECEIVERS=
EMAIL_SENDER_NAME=基金每日分析助手
EMAIL_DEDUP_ENABLED=true
EMAIL_DEDUP_WINDOW_MINUTES=180

# 【方式三】PushPlus（免 Bot 申请，微信公众号直推）
# 从 https://www.pushplus.plus/ 注册获取 Token
# PUSHPLUS_TOKEN=your_pushplus_token
# PushPlus 群组编码（可选，配置后推送到群组订阅者）
# PUSHPLUS_TOPIC=your_pushplus_topic

# 【方式四】企业微信机器人 Webhook
# 在企业微信群 -> 添加机器人 -> 复制 Webhook URL
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx

# 【可选】Markdown 转图片通知
# 适用于 Telegram / 邮件 / 企业微信，依赖 imgkit + wkhtmltoimage
# 多个渠道用逗号分隔，例如：
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,email,wecom
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000

# ===================================
# 系统配置
# ===================================
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
# 定时运行时间（北京时间，默认 14:00）
SCHEDULE_TIME=14:00
# 定时模式启动后是否立即执行一次
RUN_IMMEDIATELY=true
# 仅在中国大陆法定工作日执行（含调休）
CN_WORKDAY_ONLY=true
DATA_SOURCE_CONNECT_TIMEOUT=3.0
DATA_SOURCE_READ_TIMEOUT=8.0
DATA_SOURCE_MAX_RETRIES=0
DATA_SOURCE_RETRY_BACKOFF=0.0

# 代理配置（如需翻墙访问 Telegram / Gemini）
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809
